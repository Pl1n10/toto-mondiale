# Terraform local artifacts and secrets — never commit.
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Real variable files (the .example template stays tracked).
*.tfvars
*.tfvars.json
!*.tfvars.example

# Service-account key for the Terraform control plane — NEVER commit.
*-key.json
sa-*.json
