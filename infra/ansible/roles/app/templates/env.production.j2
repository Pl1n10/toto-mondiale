# Rendered by Ansible at {{ app_dir }}/.env.production (mode 0600).
# Mirrors .env.production.example at the repo root. Do not edit on the VM by
# hand — change group_vars / vault and re-run the app role.

# ----- Airtable backend -----
AIRTABLE_API_TOKEN={{ airtable_api_token }}
AIRTABLE_BASE_ID={{ airtable_base_id }}

# ----- Auth.js (Google-only, JWT sessions) -----
AUTH_SECRET={{ auth_secret }}
AUTH_GOOGLE_ID={{ auth_google_id }}
AUTH_GOOGLE_SECRET={{ auth_google_secret }}
AUTH_URL={{ auth_url }}

# ----- Cloudflare Tunnel -----
TUNNEL_TOKEN={{ tunnel_token }}
