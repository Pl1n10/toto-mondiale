{%- if (app_log_driver | default('gcplogs')) == 'gcplogs' -%}
{%- set logblock %}
logging:
  driver: gcplogs
  options:
    labels: com.docker.compose.service,com.docker.compose.project
{% endset -%}
{%- else -%}
{%- set logblock %}
logging:
  driver: {{ app_log_driver }}
  options:
    max-size: "10m"
    max-file: "3"
{% endset -%}
{%- endif -%}
# Rendered by Ansible onto the VM at {{ app_dir }}/docker-compose.yml.
# Three containers, no host ports. Ingress is Cloudflare Tunnel only.
# App is stateless (JWT sessions) -> no volume. Watchtower auto-updates :latest.
# Logs: driver `{{ app_log_driver | default('gcplogs') }}` -> on GCE, gcplogs
# ships container stdout/stderr to Cloud Logging (no agent). Read from the
# devbox with infra/scripts/tlogs.
services:
  app:
    image: {{ app_image }}
    restart: unless-stopped
    env_file:
      - .env.production
    expose:
      - "3000"
    labels:
      # Opt this container in to Watchtower polling.
      com.centurylinklabs.watchtower.enable: "true"
    {{ logblock | trim | indent(4) }}

  cloudflared:
    image: cloudflare/cloudflared:latest
    restart: unless-stopped
    command: tunnel --no-autoupdate run
    env_file:
      - .env.production
    depends_on:
      - app
    {{ logblock | trim | indent(4) }}

  watchtower:
    image: containrrr/watchtower:latest
    restart: unless-stopped
    command: --label-enable --cleanup --interval {{ app_watchtower_poll_seconds }}
    environment:
      # containrrr/watchtower negotiates Docker API 1.25, too old for a modern
      # daemon (min 1.40). Pin a supported version explicitly.
      DOCKER_API_VERSION: "1.44"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      # Reuse the GHCR login written by `docker login` so Watchtower can pull
      # the private package.
      - /root/.docker/config.json:/config.json:ro
    {{ logblock | trim | indent(4) }}
