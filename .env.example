# Airtable backend
# TODO(roberto): fill these in once the real Airtable base credentials are available.
AIRTABLE_API_TOKEN=
AIRTABLE_BASE_ID=

# Record ID of a Prediction Set used for dev/debug navigation.
# When empty, the dashboard falls back to a mock id and uses in-memory mock data.
DEBUG_PREDICTION_SET_ID=

# ----- Auth.js (slice #8) -----

# Random secret used to sign session cookies. Generate with:
#   openssl rand -base64 32
AUTH_SECRET=

# Google OAuth (slice #8b)
# Create on https://console.cloud.google.com → Credentials → OAuth Client (Web).
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# Also add the production URL when deploying.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend (slice #8c — magic link email)
# Get API key from https://resend.com after verifying a sender domain.
# AUTH_RESEND_FROM should be an address on that verified domain.
AUTH_RESEND_KEY=
AUTH_RESEND_FROM=
