# Template for the production env file on the GCP VM.
# Copy to `.env.production` (gitignored) and fill in real values.

# ----- Airtable backend -----
AIRTABLE_API_TOKEN=
AIRTABLE_BASE_ID=appPV77eshDFrfgII

# ----- Auth.js (Google-only, JWT sessions) -----
# Generate a fresh secret for prod: openssl rand -base64 32
