AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Public origin behind the Cloudflare Tunnel — must match the Google
# redirect URI added in slice #12.
AUTH_URL=https://t0t0m0ndlale.online

# ----- Cloudflare Tunnel (used by the cloudflared container) -----
# Token from the Zero Trust dashboard tunnel (slice #10).
TUNNEL_TOKEN=
